// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// 项目表
model Project {
  id              String        @id @default(uuid())
  title           String
  genre           String
  synopsis        String?
  targetWordCount Int          @default(100000)
  currentWordCount Int       @default(0)
  status          String       @default("draft")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // 关联关系
  outlines        Outline[]
  characters      Character[]
  worlds          World[]
}

// 大纲表
model Outline {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  summary     String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chapters    Chapter[]
}

// 章节表
model Chapter {
  id          String   @id @default(uuid())
  outlineId   String
  outline     Outline  @relation(fields: [outlineId], references: [id], onDelete: Cascade)
  title       String
  goal        String?
  startHint   String?
  endHint     String?
  content     String?
  wordCount   Int      @default(0)
  order       Int      @default(0)
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 角色表
model Character {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  role        String?
  appearance  String?
  personality String?
  background  String?
  abilities   String?
  status      String   @default("planned")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 世界观表
model World {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  category    String
  content     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}